{
  "name": "bartoszwolak/wp-ai-page-builder",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.1",
    "vlucas/phpdotenv": "^5.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "WpAiAgent\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WpAiAgent\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
