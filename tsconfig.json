{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["assets/src/*"]
    },
    "skipLibCheck": true,
    "types": ["vitest/globals"]
  },
  "include": ["assets/src"],
  "exclude": ["node_modules", "assets/build"]
}
